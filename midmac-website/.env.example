# MongoDB: Payload deployment docs mention DATABASE_URL; either works.
DATABASE_URI=mongodb://127.0.0.1/your-database-name
# DATABASE_URL=
#
# Atlas: pick a stable region (e.g. AWS eu-central-1 / eu-west-1) when creating the cluster.
# Network Access must allow your IP (local dev) and Vercel (use 0.0.0.0/0 for serverless).
# Sanity check: pnpm run check:db

PAYLOAD_SECRET=YOUR_SECRET_HERE

# Production: canonical site URL for Payload serverURL (no trailing slash)
# NEXT_PUBLIC_SERVER_URL=https://www.midmac.design

# Supabase Storage (S3-compatible). All five must be set for the S3 plugin to load.
# If any are missing, Payload skips S3 (warns in logs); media uploads may fail.
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=eu-central-1
S3_ENDPOINT=https://YOUR_PROJECT_REF.storage.supabase.co

RESEND_API_KEY=

# Optional: sync production env for local debugging (requires Vercel CLI + login)
# vercel env pull .env.vercel.local
# Then: cp .env.vercel.local .env   (or merge by hand)

# Debug /api/health JSON error body on Vercel only (remove after use):
# DEBUG_DB_HEALTH=1
